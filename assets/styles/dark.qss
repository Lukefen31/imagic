/* ============================================================
   Imagic — Premium Dark Theme Stylesheet
   ============================================================ */

/* --- Base Window --- */
QMainWindow {
    background-color: #0d0d0d;
    color: #d6d6db;
}

/* --- Menu Bar --- */
QMenuBar {
    background-color: #111114;
    color: #d6d6db;
    border-bottom: 1px solid #232327;
    padding: 2px 0;
    font-size: 12px;
}

QMenuBar::item {
    padding: 5px 12px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #1e1e22;
}

QMenu {
    background-color: #16161a;
    color: #d6d6db;
    border: 1px solid #232327;
    border-radius: 8px;
    padding: 4px 0;
}

QMenu::item {
    padding: 7px 24px 7px 16px;
    border-radius: 4px;
    margin: 1px 4px;
}

QMenu::item:selected {
    background-color: #e89530;
    color: #111;
}

QMenu::separator {
    height: 1px;
    background: #232327;
    margin: 4px 12px;
}

/* --- Toolbar --- */
QToolBar {
    background-color: #131316;
    border: none;
    border-bottom: 1px solid #232327;
    spacing: 6px;
    padding: 4px 8px;
}

QToolBar QToolButton {
    color: #b0b0b6;
    padding: 5px 10px;
    border-radius: 5px;
    font-size: 11px;
}

QToolBar QToolButton:hover {
    background-color: #1e1e22;
}

QToolBar QToolButton:pressed {
    background-color: #28282d;
}

/* --- Status Bar --- */
QStatusBar {
    background-color: #111114;
    color: #78787f;
    border-top: 1px solid #232327;
    font-size: 11px;
    padding: 2px 8px;
}

QStatusBar::item {
    border: none;
}

/* --- Dock Widgets --- */
QDockWidget {
    color: #b0b0b6;
    titlebar-close-icon: none;
}

QDockWidget::title {
    background-color: #16161a;
    padding: 7px 12px;
    border-bottom: 1px solid #232327;
}

/* --- Scroll Area --- */
QScrollArea {
    background-color: #0d0d0d;
    border: none;
}

QScrollBar:vertical {
    width: 6px;
    background: transparent;
    border: none;
}

QScrollBar::handle:vertical {
    background: rgba(100, 100, 106, 0.35);
    border-radius: 3px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(100, 100, 106, 0.6);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
    height: 0;
    border: none;
}

QScrollBar:horizontal {
    height: 6px;
    background: transparent;
    border: none;
}

QScrollBar::handle:horizontal {
    background: rgba(100, 100, 106, 0.35);
    border-radius: 3px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background: rgba(100, 100, 106, 0.6);
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal,
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: transparent;
    width: 0;
    border: none;
}

/* --- Tables --- */
QTableWidget, QTableView {
    background-color: #0d0d0d;
    alternate-background-color: #121215;
    color: #d6d6db;
    gridline-color: #232327;
    selection-background-color: rgba(232, 149, 48, 0.15);
    selection-color: #fff;
    border: 1px solid #232327;
    border-radius: 6px;
    font-size: 12px;
}

QTableWidget::item, QTableView::item {
    padding: 6px 8px;
    border-bottom: 1px solid #19191d;
}

QTableWidget::item:selected, QTableView::item:selected {
    background-color: rgba(232, 149, 48, 0.12);
}

QHeaderView::section {
    background-color: #16161a;
    color: #78787f;
    padding: 7px 10px;
    border: none;
    border-bottom: 1px solid #232327;
    font-weight: 600;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* --- Buttons --- */
QPushButton {
    background-color: #1e1e22;
    color: #b0b0b6;
    border: 1px solid #333338;
    padding: 7px 16px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #28282d;
    border-color: #3e3e44;
    color: #d6d6db;
}

QPushButton:pressed {
    background-color: #222226;
}

QPushButton:disabled {
    background-color: #16161a;
    color: #404045;
    border-color: #232327;
}

QPushButton:focus {
    border-color: #e89530;
}

/* --- Input Fields --- */
QLineEdit, QSpinBox, QDoubleSpinBox {
    background-color: #16161a;
    color: #d6d6db;
    border: 1px solid #333338;
    padding: 7px 10px;
    border-radius: 5px;
    font-size: 12px;
    selection-background-color: rgba(232, 149, 48, 0.25);
}

QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #e89530;
}

QLineEdit:hover, QSpinBox:hover, QDoubleSpinBox:hover {
    border-color: #3e3e44;
}

QComboBox {
    background-color: #16161a;
    color: #d6d6db;
    border: 1px solid #333338;
    padding: 7px 10px;
    border-radius: 5px;
    font-size: 12px;
}

QComboBox:hover {
    border-color: #3e3e44;
}

QComboBox:focus {
    border-color: #e89530;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox QAbstractItemView {
    background-color: #16161a;
    color: #d6d6db;
    border: 1px solid #333338;
    border-radius: 6px;
    selection-background-color: rgba(232, 149, 48, 0.2);
    padding: 4px;
}

/* --- Progress Bar --- */
QProgressBar {
    background-color: #16161a;
    border: none;
    border-radius: 3px;
    text-align: center;
    color: #d6d6db;
    font-size: 10px;
    min-height: 6px;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #e89530, stop:1 #f5ad4a);
    border-radius: 3px;
}

/* --- Checkbox & Radio --- */
QCheckBox {
    color: #d6d6db;
    spacing: 8px;
    font-size: 12px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid #3e3e44;
    background: #16161a;
}

QCheckBox::indicator:checked {
    background-color: #e89530;
    border-color: #e89530;
}

QCheckBox::indicator:hover {
    border-color: #e89530;
}

QRadioButton {
    color: #d6d6db;
    spacing: 8px;
    font-size: 12px;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border-radius: 8px;
    border: 1px solid #3e3e44;
    background: #16161a;
}

QRadioButton::indicator:checked {
    background-color: #e89530;
    border-color: #e89530;
}

/* --- Group Box --- */
QGroupBox {
    color: #d6d6db;
    border: 1px solid #232327;
    border-radius: 8px;
    margin-top: 12px;
    padding: 20px 12px 12px;
    font-weight: 600;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 2px 10px;
    color: #e89530;
    font-size: 11px;
}

/* --- Tabs --- */
QTabWidget::pane {
    border: 1px solid #232327;
    border-radius: 6px;
    background-color: #0d0d0d;
    top: -1px;
}

QTabBar::tab {
    background-color: #16161a;
    color: #78787f;
    padding: 9px 18px;
    border: 1px solid #232327;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    margin-right: 2px;
    font-size: 12px;
}

QTabBar::tab:hover {
    background-color: #1e1e22;
    color: #d6d6db;
}

QTabBar::tab:selected {
    background-color: #0d0d0d;
    color: #e89530;
    border-bottom: 2px solid #e89530;
    font-weight: 600;
}

/* --- Slider --- */
QSlider::groove:horizontal {
    height: 2px;
    background: #28282d;
    border-radius: 1px;
}

QSlider::handle:horizontal {
    width: 11px;
    height: 11px;
    margin: -5px 0;
    background: #e89530;
    border-radius: 6px;
    border: 1.5px solid #121215;
}

QSlider::handle:horizontal:hover {
    background: #f5ad4a;
    border-color: #0d0d0d;
}

QSlider::sub-page:horizontal {
    background: #e89530;
    border-radius: 1px;
}

/* --- Splitter --- */
QSplitter::handle {
    background: #232327;
    width: 1px;
}

QSplitter::handle:hover {
    background: rgba(232, 149, 48, 0.4);
}

/* --- Tooltips --- */
QToolTip {
    background-color: #19191d;
    color: #d6d6db;
    border: 1px solid #333338;
    border-radius: 5px;
    padding: 5px 9px;
    font-size: 11px;
}

/* --- Dialog --- */
QDialog {
    background-color: #0d0d0d;
    color: #d6d6db;
}

/* --- Label --- */
QLabel {
    color: #d6d6db;
}

/* --- Message Box --- */
QMessageBox {
    background-color: #16161a;
}

QMessageBox QPushButton {
    min-width: 80px;
    padding: 7px 18px;
}

/* --- File Dialog --- */
QFileDialog {
    background-color: #0d0d0d;
}
